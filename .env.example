# This project is a static Cloudflare Pages app.
# Do not put production secrets in client-side files.
#
# Supabase anon keys are public browser keys and belong in config.js.
# Supabase service_role keys must never be committed or shipped to the browser.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
